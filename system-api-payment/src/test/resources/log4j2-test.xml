<?xml version="1.0" encoding="utf-8"?>
<Configuration packages="org.mule.extension.logging">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%-5p %d [%t] %c: %m%n" />
        </Console>
    </Appenders>
    <Loggers>
        <!-- App logs -->
        <AsyncLogger name="com.mycompany" level="INFO"/>
        <!-- Mule logs -->
        <AsyncLogger name="org.mule.service" level="INFO"/>
        <AsyncLogger name="org.mule.runtime.core.internal.processor" level="INFO"/>
        <AsyncRoot level="INFO">
            <AppenderRef ref="Console" />
        </AsyncRoot>
    </Loggers>
</Configuration>
